---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Signal lost — Jezweb Skills" noindex={true}>
  <section class="hero hero--short" style="text-align:center">
    <div class="sky-glow"></div>
    <div class="horizon"></div>
    <div class="grid-floor"></div>
    <div class="scrim" style="background:radial-gradient(120% 80% at 50% 40%, rgba(6,5,7,0.9), transparent 70%)"></div>
    <div class="hero-body" style="display:flex;flex-direction:column;align-items:center">
      <p class="term">&gt; signal lost // 404<span class="cursor"></span></p>
      <h1 class="hero-title" style="margin-top:18px">This page <span class="glow">isn't here.</span></h1>
      <p class="lead" style="margin:18px auto 0">
        That link doesn't go anywhere any more, or never did. Head back to the
        catalogue, or browse the skills on GitHub.
      </p>
      <div class="cta-row" style="justify-content:center">
        <a href="/" class="ribbon">Back to the catalogue</a>
        <a href="https://github.com/jezweb" class="ribbon ribbon-ghost" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </section>
</Layout>
